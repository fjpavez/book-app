{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@features/*": ["src/features/*"],
      "@domain/*": ["src/domain/*"],
      "@data/*": ["src/data/*"],
      "@core/*": ["src/core/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
